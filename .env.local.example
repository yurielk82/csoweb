# ===========================================
# CSO Settlement Portal - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Secret (generate a random string)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters

# Resend Email Configuration
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key

# Email Settings
EMAIL_FROM=CSO Portal <noreply@your-domain.com>
ADMIN_EMAIL=admin@your-domain.com

# SMTP Configuration (Optional - 관리자 대시보드에서 설정 가능)
# 하이웍스 예시: smtps.hiworks.com:465 (SSL)
# SMTP 설정은 DB(company_settings)에 저장되므로 환경변수 불필요.
# 관리자 > 사이트 설정 > 이메일 발송 설정에서 구성하세요.

# Base URL (for email links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 국세청 사업자등록정보 진위확인 및 상태조회 API
# 공공데이터포털(data.go.kr)에서 활용신청 후 발급
# https://www.data.go.kr/data/15081808/openapi.do
# 사용처: /api/verify-biz (회원가입 사업자번호 실시간 인증)
NTS_API_KEY=your-nts-api-service-key

# 건강보험심사평가원 병원정보서비스 / 약국정보서비스 API
# 공공데이터포털(data.go.kr)에서 활용신청 후 발급
# https://www.data.go.kr/data/15001698/openapi.do (병원정보서비스)
# https://www.data.go.kr/data/15001699/openapi.do (약국정보서비스)
# 사용처: Supabase Edge Function (sync-hospitals), 시스템 상태 표시
HIRA_API_KEY=your-hira-api-service-key
