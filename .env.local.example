# ===========================================
# CSO Settlement Portal - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Secret (generate a random string)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters

# Resend Email Configuration
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key

# Email Settings
EMAIL_FROM=CSO Portal <noreply@your-domain.com>
ADMIN_EMAIL=admin@your-domain.com

# Base URL (for email links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 국세청 사업자등록정보 진위확인 및 상태조회 API
# 공공데이터포털(data.go.kr)에서 활용신청 후 발급
# https://www.data.go.kr/data/15081808/openapi.do
# 사용처: /api/verify-biz (회원가입 사업자번호 실시간 인증)
NTS_API_KEY=your-nts-api-service-key
